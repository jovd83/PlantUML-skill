@startuml
!include ../assets/premium-theme.puml
header "Premium E-commerce Management"
footer "Generated by plantuml-skill"

left to right direction

actor "Customer" as C
actor "Agent" as A
actor "Manager" as M
actor "System Admin" as Admin

rectangle "E-Commerce Platform" {
    usecase "Search Products" as UC1
    usecase "Add to Cart" as UC2
    usecase "Checkout" as UC3
    usecase "View Order History" as UC4
    usecase "Cancel Order" as UC5
    usecase "Issue Refund" as UC6
    usecase "Manage Inventory" as UC7
    usecase "Update Pricing" as UC8
    usecase "Generate Sales Report" as UC9
    usecase "View Analytics" as UC10
    usecase "Monitor System Health" as UC11
    usecase "Backup Database" as UC12
    usecase "Reset User Password" as UC13
    usecase "Configure Payments" as UC14
}

C --> UC1
C --> UC2
C --> UC3
C --> UC4
C --> UC5

A --> UC5
A --> UC6
A --> UC13

M --> UC7
M --> UC8
M --> UC9
M --> UC10

Admin --> UC11
Admin --> UC12
Admin --> UC14
Admin --> UC13
@enduml
